NODE_ENV=development
PORT=3000

# CORS — comma-separated browser origins (scheme + host + port). Required in production.
# Examples: http://localhost:5173,http://localhost:5174,https://admin.yourdomain.com,https://retailer.yourdomain.com
# Native mobile HTTP clients typically send no Origin header and are still allowed.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# MongoDB
DATABASE_URL=mongodb://localhost:27017/snag

# JWT
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
